{
  "name": "wechat-claude-bridge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "tsx app.ts",
    "dev:login": "tsx app.ts --login",
    "start": "node dist/app.js",
    "login": "node dist/app.js --login",
    "build": "tsc",
    "build:all": "pnpm build && pnpm -r build",
    "typecheck": "tsc --noEmit",
    "test": "pnpm -r run test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
